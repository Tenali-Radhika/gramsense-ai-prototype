# GramSense AI - Environment Configuration
# Copy this file to .env and fill in your AWS credentials

# AWS Credentials (Required for deployment and AWS service integration)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# Optional: For specific AWS services
# S3_BUCKET_NAME=your-gramsense-bucket
# DYNAMODB_TABLE=gramsense-prices
# EC2_INSTANCE_TYPE=t3.micro

# Application Settings
DEBUG=True
LOG_LEVEL=INFO

# Optional: Real API integrations (for production)
# AGMARKNET_API_KEY=
# IMD_API_KEY=
# OPENWEATHER_API_KEY=